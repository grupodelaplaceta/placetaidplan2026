# PlacetaID - variables de entorno (no incluir valores reales)
# Esto se usa en backend / CI y NUNCA en el frontend estático.

# Database
DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<database>?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://<user>:<password>@<host>:<port>/<database>?sslmode=require

# OAuth/OIDC
OAUTH_CLIENT_ID=placetaid-client
OAUTH_CLIENT_SECRET=<secret>
OAUTH_REDIRECT_URI=https://app.tudominio.com/callback
OAUTH_STATE_SECRET=<random-string>

# API y seguridad
API_BASE_URL=https://placetaid.tudominio.com
NODE_ENV=production
SESSION_SECRET=<random-secret-session>
JWT_SECRET=<jwt-secret>

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=5

# Email/alertas (opcional)
SMTP_HOST=<smtp-host>
SMTP_PORT=587
SMTP_USER=<smtp-user>
SMTP_PASSWORD=<smtp-password>
