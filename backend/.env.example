# Database
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/placetaid_db

# JWT
JWT_SECRET_KEY=your-secret-key-here-min-32-chars-long

# Encryption
MASTER_ENCRYPTION_KEY=your-32-byte-base64-encoded-key-here
DIP_HASH_SALT=your-random-salt-here

# Flask
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-flask-secret-key

# Rate Limiting (Redis)
REDIS_URL=redis://localhost:6379/0

# CORS Origins
ALLOWED_ORIGINS=https://id.laplaceta.org,https://loteria.laplaceta.org,https://notaries.laplaceta.org

# Logging
LOG_LEVEL=INFO
