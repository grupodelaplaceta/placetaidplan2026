{
  "buildCommand": "pip install -r requirements.txt",
  "framework": "python",
  "github": {
    "silent": true
  },
  "functions": {
    "api/**/*.py": {
      "runtime": "python3.11",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ],
  "env": {
    "FLASK_ENV": "production",
    "DATABASE_URL": "sqlite:///placetaid_demo.db",
    "JWT_SECRET_KEY": "demo-jwt-secret-key-2026-placetaid",
    "MASTER_ENCRYPTION_KEY": "demo-encryption-key-32-chars-long!!!",
    "DIP_HASH_SALT": "demo-dip-hash-salt-secure-2026",
    "REDIS_URL": "redis://localhost:6379/0",
    "ALLOWED_ORIGINS": "https://placetaidplan2026.vercel.app,http://localhost:3000"
  }
}

