# PlacetaID - Vercel Environment Variables

# ======== DATABASE ========
# For Vercel, use serverless database services:
# Options:
# 1. Supabase (PostgreSQL) - RECOMMENDED
#    postgresql://user:password@host/database?sslmode=require
# 2. PlanetScale (MySQL)
#    mysql://user:password@host/database?sslMode=REQUIRE
# 3. MongoDB Atlas (NoSQL)
#    mongodb+srv://user:password@cluster.mongodb.net/database

DATABASE_URL=postgresql://user:password@db.host/placetaid_db?sslmode=require


# ======== JWT & SECURITY ========
# Generate strong keys:
# JWT_SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"
# MASTER_ENCRYPTION_KEY: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# DIP_HASH_SALT: python -c "import secrets; print(secrets.token_hex(16))"

JWT_SECRET_KEY=your-64-character-hex-string-here-min-64-chars
MASTER_ENCRYPTION_KEY=your-base64-encoded-32-byte-key-here
DIP_HASH_SALT=your-random-salt-here-min-32-chars


# ======== REDIS ========
# For Vercel, use Upstash Redis:
# https://upstash.com (free tier available)
# Format: redis://default:password@host:port

REDIS_URL=redis://default:password@host.upstash.io:port


# ======== CORS & ORIGINS ========
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com,https://id.yourdomain.com


# ======== FLASK ========
FLASK_ENV=production
FLASK_DEBUG=False


# ======== OPTIONAL: MONITORING ========
# Sentry for error tracking (optional)
SENTRY_DSN=https://key@sentry.io/project-id

# LogRocket for session replay (optional)
LOGROCKET_ID=org/project-id
